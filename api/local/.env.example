POSTGRES_PASSWORD=postgres_password_dev

HASURA_GRAPHQL_DATABASE_URL=postgres://postgres:postgres_password_dev@postgres:5432/postgres
HASURA_GRAPHQL_ADMIN_SECRET=hasura_admin_secret_dev
HASURA_GRAPHQL_ENABLE_CONSOLE=true
HASURA_GRAPHQL_DEV_MODE=true
HASURA_GRAPHQL_ENABLE_TELEMETRY=false
HASURA_GRAPHQL_UNAUTHORIZED_ROLE=anonymous 
HASURA_GRAPHQL_JWT_SECRET=
HASURA_GRAPHQL_CORS_DOMAIN=*
HASURA_GRAPHQL_CONSOLE_ASSETS_DIR=/srv/console-assets
HASURA_GRAPHQL_ENABLED_LOG_TYPES=startup, http-log, webhook-log, websocket-log, query-log
ACTION_BASE_URL=http://host.docker.internal:8080
HOOK_SECRET=hasura_hook_secret_dev
HOOK_SECRET_HEADER_NAME=x-hook-secret
HASURA_GRAPHQL_JWT_SECRET={"type":"HS256","key":"dev-super-secret-key-at-least-32-characters-long"}